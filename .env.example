OPENROUTER_API_KEY=
OPENROUTER_MODEL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Spotify playlist feature (server-side; playlists are created in the site
# owner's Spotify account and shared with visitors by link, because Spotify
# Development Mode does not allow the general public to authenticate).
# 1. Create an app at https://developer.spotify.com/dashboard (Web API enabled)
#    and register redirect URI http://127.0.0.1:8888/callback
# 2. Run: npx tsx scripts/spotify-owner-auth.ts  (prints the refresh token)
# 3. Set all three below (SPOTIFY_CLIENT_ID falls back to the committed
#    default client id if omitted).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
